# ===========================================
# Bazi Platform - Environment Variables
# Copy this file to .env and fill in values
# ===========================================

# ---- Database ----
DATABASE_URL="postgresql://bazi_user:bazi_dev_password@localhost:5432/bazi_platform"
REDIS_URL="redis://localhost:6379"

# ---- Clerk Authentication ----
CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# ---- AI Providers ----
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."
GOOGLE_AI_API_KEY="..."

# ---- Stripe Payments ----
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ---- Bazi Engine ----
BAZI_ENGINE_URL="http://localhost:5001"

# ---- Cloudflare R2 (dashboard banner image uploads) ----
# Optional — the app boots without these; the admin banner /upload endpoint
# fails loudly when unset. Create an R2 bucket with public access + an API
# token (Object Read/Write). R2_PUBLIC_BASE_URL is the bucket's public URL
# (pub-<hash>.r2.dev or a custom domain) WITHOUT a trailing slash.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="bazi-banners"
R2_PUBLIC_BASE_URL=""
# Web (next.config.js) — host of R2_PUBLIC_BASE_URL, added to CSP img-src +
# images.remotePatterns. e.g. "pub-<hash>.r2.dev" or "cdn.example.com".
NEXT_PUBLIC_R2_PUBLIC_HOST=""

# ---- App Config ----
NODE_ENV="development"
PORT=4000
CORS_ORIGINS="http://localhost:3000,http://localhost:8081"

# ---- Development Overrides ----
# Set to "true" only for development without AI keys (shows mock AI data on direct engine calls)
NEXT_PUBLIC_USE_MOCK_AI=""

# ---- Sentry Error Tracking ----
SENTRY_DSN=""

# ---- PostHog Analytics ----
POSTHOG_API_KEY=""
POSTHOG_HOST="https://app.posthog.com"
