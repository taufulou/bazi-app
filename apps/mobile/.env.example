# Mobile app environment variables. Copy to `.env` and fill in.
# Only EXPO_PUBLIC_* vars are exposed to the app bundle at build time.

# --- Required for the app to run ---
# Clerk publishable key (same value as the web app's NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# NestJS API base URL.
#   iOS simulator:      http://localhost:4000
#   Android emulator:   http://10.0.2.2:4000   (src/lib/env.ts rewrites localhost -> 10.0.2.2 automatically in __DEV__)
#   Physical device:    http://<your-mac-LAN-ip>:4000
EXPO_PUBLIC_API_URL=http://localhost:4000

# --- Optional (features light up when set; absent = graceful no-op) ---
# Base URL for remotely-served assets (mascot PNGs etc.). Empty by default —
# mascot loading (M2+) needs this pointed at the web app's public URL or a CDN.
EXPO_PUBLIC_ASSETS_URL=
# PostHog analytics project key.
EXPO_PUBLIC_POSTHOG_KEY=
# Sentry DSN for crash reporting (client-side runtime — must be EXPO_PUBLIC_).
EXPO_PUBLIC_SENTRY_DSN=
