{
  "expo": {
    "name": "天命",
    "slug": "tianming",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "tianming",
    "userInterfaceStyle": "light",
    "backgroundColor": "#FFF3E0",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tianming.app",
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF3E0"
      },
      "package": "com.tianming.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-image",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-sharing",
      "@sentry/react-native",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFF3E0",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "b7c274f0-ce98-42ca-93c9-cb5af4faff3a"
      }
    },
    "owner": "tian-ming"
  }
}
