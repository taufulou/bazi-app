# ===========================================
# Bazi Platform — Web (Next.js) Environment
# Copy this file to apps/web/.env.local and fill in values.
#
# IMPORTANT: Next.js reads env from THIS app directory (apps/web/.env.local),
# NOT the monorepo-root .env. A var documented only in the root .env.example
# will NOT reach the web app unless it is also set here.
#
# Vars prefixed NEXT_PUBLIC_ are inlined into the browser bundle at build/start
# time — never put a real secret behind a NEXT_PUBLIC_ name. Restart `next dev`
# after changing any of these (NEXT_PUBLIC_ vars are read at server start).
# ===========================================

# ---- Clerk Authentication ----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."            # secret — used by middleware / server components

# Clerk routing
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/"

# ---- API (NestJS) base URL ----
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ---- Stripe (publishable key only — the secret key lives in the API env) ----
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ---- Cloudflare R2 — dashboard banner image host ----
# Host of the R2 bucket's public URL (pub-<hash>.r2.dev or a custom domain),
# WITHOUT protocol or trailing slash. next.config.js injects this into BOTH the
# CSP img-src directive AND images.remotePatterns.
#
# REQUIRED for the dashboard banner: if empty, the CSP omits the R2 host and the
# browser silently blocks the banner <img> — HeroBanner renders broken/blank
# images even though the files themselves return HTTP 200. Must match the host
# embedded in your stored banner image URLs (R2_PUBLIC_BASE_URL on the API side).
NEXT_PUBLIC_R2_PUBLIC_HOST=""

# ---- Development Overrides ----
# "true" only for dev without AI keys (shows mock AI data on direct engine calls)
NEXT_PUBLIC_USE_MOCK_AI=""
