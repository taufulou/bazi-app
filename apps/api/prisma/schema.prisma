// ============================================================
// Bazi Platform - Database Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Users (Clerk handles auth, we store app-specific data)
// ============================================================

model User {
  id                String           @id @default(uuid())
  clerkUserId       String           @unique @map("clerk_user_id")
  name              String?
  avatarUrl         String?          @map("avatar_url")
  subscriptionTier  SubscriptionTier @default(FREE) @map("subscription_tier")
  credits           Int              @default(0)
  languagePref      Language         @default(ZH_TW) @map("language_pref")
  deviceFingerprint String?          @map("device_fingerprint")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  birthProfiles       BirthProfile[]
  baziReadings        BaziReading[]
  baziComparisons     BaziComparison[]
  subscriptions       Subscription[]
  transactions        Transaction[]
  aiUsageLogs         AIUsageLog[]
  adRewardLogs        AdRewardLog[]
  sectionUnlocks      SectionUnlock[]
  monthlyCreditsLogs  MonthlyCreditsLog[]
  creditLedgerEntries CreditLedger[]
  chatSessions        ChatSession[]
  chatMonthlyUsages   ChatMonthlyUsage[]

  @@map("users")
}

// ============================================================
// Birth Profiles (users can save multiple)
// ============================================================

model BirthProfile {
  id              String          @id @default(uuid())
  userId          String          @map("user_id")
  name            String
  birthDate       DateTime        @map("birth_date") @db.Date
  birthTime       String?         @map("birth_time") // HH:MM format; null when hourKnown=false (時辰未知)
  hourKnown       Boolean         @default(true) @map("hour_known") // false → 3-pillar (年/月/日) reading; immutable after creation
  birthCity       String          @map("birth_city")
  birthTimezone   String          @map("birth_timezone") // IANA timezone
  birthLongitude  Float?          @map("birth_longitude")
  birthLatitude   Float?          @map("birth_latitude")
  gender          Gender
  relationshipTag RelationshipTag @default(SELF) @map("relationship_tag")
  isPrimary       Boolean         @default(false) @map("is_primary")
  isLunarDate     Boolean         @default(false) @map("is_lunar_date")
  lunarBirthDate  String?         @map("lunar_birth_date") // Original lunar date "YYYY-MM-DD" if isLunarDate=true
  isLeapMonth     Boolean         @default(false) @map("is_leap_month") // Whether the lunar date is in a leap month (閏月)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relations
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  readings        BaziReading[]
  comparisonsA    BaziComparison[]       @relation("ProfileA")
  comparisonsB    BaziComparison[]       @relation("ProfileB")
  fortuneSnapshots DailyFortuneSnapshot[]
  chatSessions    ChatSession[]          // Phase Fortune — FORTUNE chat sessions anchored to this profile

  @@index([userId])
  @@map("birth_profiles")
}

// ============================================================
// Bazi Readings (generated reports — single person)
// ============================================================

model BaziReading {
  id               String      @id @default(uuid())
  userId           String      @map("user_id")
  birthProfileId   String      @map("birth_profile_id")
  readingType      ReadingType @map("reading_type")
  calculationData  Json        @map("calculation_data") // Full Bazi calculation JSON
  aiInterpretation Json?       @map("ai_interpretation") // Structured JSON with preview/full per section
  aiProvider       AIProvider? @map("ai_provider")
  aiModel          String?     @map("ai_model")
  tokenUsage       Json?       @map("token_usage") // { inputTokens, outputTokens, totalTokens, estimatedCostUsd }
  creditsUsed      Int         @default(0) @map("credits_used")
  targetYear       Int?        @map("target_year") // For annual readings
  targetMonth      Int?        @map("target_month") // For monthly readings (1-12)
  targetDay        String?     @map("target_day") // For daily readings (YYYY-M-D)
  questionText     String?     @map("question_text") @db.Text // For Q&A readings
  createdAt        DateTime    @default(now()) @map("created_at")

  // AI failure / refund tracking (added by ai-retry-and-credit-refund plan)
  failedReason          String?   @map("failed_reason")
  isDegraded            Boolean   @default(false) @map("is_degraded")
  refundedAt            DateTime? @map("refunded_at")
  regenerationCount     Int       @default(0) @map("regeneration_count")
  regenerationExhausted Boolean   @default(false) @map("regeneration_exhausted")

  // Relations
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  birthProfile        BirthProfile   @relation(fields: [birthProfileId], references: [id], onDelete: Cascade)
  aiUsageLogs         AIUsageLog[]
  creditLedgerEntries CreditLedger[]
  chatSessions        ChatSession[]

  @@index([userId])
  @@index([birthProfileId])
  @@map("bazi_readings")
}

// ============================================================
// Bazi Compatibility Readings (two-person comparison)
// ============================================================

model BaziComparison {
  id                 String         @id @default(uuid())
  userId             String         @map("user_id")
  profileAId         String         @map("profile_a_id")
  profileBId         String         @map("profile_b_id")
  comparisonType     ComparisonType @map("comparison_type")
  calculationData    Json           @map("calculation_data")
  aiInterpretation   Json?          @map("ai_interpretation")
  aiProvider         AIProvider?    @map("ai_provider")
  aiModel            String?        @map("ai_model")
  tokenUsage         Json?          @map("token_usage")
  creditsUsed        Int            @default(0) @map("credits_used")
  lastCalculatedYear Int?           @map("last_calculated_year")
  createdAt          DateTime       @default(now()) @map("created_at")

  // AI failure / refund tracking (added by ai-retry-and-credit-refund plan)
  failedReason          String?   @map("failed_reason")
  isDegraded            Boolean   @default(false) @map("is_degraded")
  refundedAt            DateTime? @map("refunded_at")
  regenerationCount     Int       @default(0) @map("regeneration_count")
  regenerationExhausted Boolean   @default(false) @map("regeneration_exhausted")

  // Relations
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileA            BirthProfile   @relation("ProfileA", fields: [profileAId], references: [id], onDelete: Cascade)
  profileB            BirthProfile   @relation("ProfileB", fields: [profileBId], references: [id], onDelete: Cascade)
  creditLedgerEntries CreditLedger[]
  chatSessions        ChatSession[] // Phase 3 — COMPATIBILITY chat sessions referencing this comparison

  @@index([userId])
  @@map("bazi_comparisons")
}

// ============================================================
// Subscriptions
// ============================================================

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @map("user_id")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  appleOriginalTxId    String?            @unique @map("apple_original_tx_id")
  googlePurchaseToken  String?            @unique @map("google_purchase_token")
  planTier             SubscriptionTier   @map("plan_tier")
  status               SubscriptionStatus @map("status")
  platform             PaymentPlatform    @default(STRIPE) @map("platform")
  currentPeriodStart   DateTime           @map("current_period_start")
  currentPeriodEnd     DateTime           @map("current_period_end")
  cancelledAt          DateTime?          @map("cancelled_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("subscriptions")
}

// ============================================================
// Transactions
// ============================================================

model Transaction {
  id              String          @id @default(uuid())
  userId          String          @map("user_id")
  stripePaymentId String?         @unique @map("stripe_payment_id")
  amount          Decimal         @db.Decimal(10, 2)
  currency        String          @default("USD")
  type            TransactionType
  description     String?
  platform        PaymentPlatform @default(STRIPE) @map("platform")
  createdAt       DateTime        @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("transactions")
}

// ============================================================
// Reading Cache (for performance)
// ============================================================

model ReadingCache {
  id                 String      @id @default(uuid())
  birthDataHash      String      @map("birth_data_hash") // SHA-256(birth_datetime_utc + birth_lng_lat + gender + reading_type)
  readingType        ReadingType @map("reading_type")
  calculationJson    Json        @map("calculation_json")
  interpretationJson Json?       @map("interpretation_json")
  createdAt          DateTime    @default(now()) @map("created_at")
  expiresAt          DateTime    @map("expires_at")

  @@unique([birthDataHash, readingType])
  @@index([expiresAt])
  @@map("reading_cache")
}

// ============================================================
// AI Usage Tracking (cost monitoring)
// ============================================================

model AIUsageLog {
  id           String       @id @default(uuid())
  userId       String?      @map("user_id")
  readingId    String?      @map("reading_id")
  readingType  ReadingType? @map("reading_type")
  aiProvider   AIProvider   @map("ai_provider")
  aiModel      String       @map("ai_model")
  inputTokens  Int          @map("input_tokens")
  outputTokens Int          @map("output_tokens")
  costUsd      Decimal      @map("cost_usd") @db.Decimal(10, 6)
  latencyMs    Int          @map("latency_ms")
  isCacheHit   Boolean      @default(false) @map("is_cache_hit")
  createdAt    DateTime     @default(now()) @map("created_at")

  // Relations
  user    User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  reading BaziReading? @relation(fields: [readingId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([aiProvider])
  @@index([aiProvider, createdAt])
  @@index([createdAt, readingType])
  @@map("ai_usage_log")
}

// ============================================================
// ADMIN-CONFIGURABLE TABLES
// ============================================================

// Service/Product Catalog
model Service {
  id                      String      @id @default(uuid())
  slug                    String      @unique
  nameZhTw                String      @map("name_zh_tw")
  nameZhCn                String      @map("name_zh_cn")
  descriptionZhTw         String      @map("description_zh_tw")
  descriptionZhCn         String      @map("description_zh_cn")
  type                    ReadingType
  creditCost              Int         @map("credit_cost")
  sectionUnlockCreditCost Int         @default(1) @map("section_unlock_credit_cost") // Admin-configurable per reading type
  isActive                Boolean     @default(true) @map("is_active")
  sortOrder               Int         @default(0) @map("sort_order")
  createdAt               DateTime    @default(now()) @map("created_at")
  updatedAt               DateTime    @updatedAt @map("updated_at")

  @@map("services")
}

// Subscription Plans
model Plan {
  id               String   @id @default(uuid())
  slug             String   @unique
  nameZhTw         String   @map("name_zh_tw")
  nameZhCn         String   @map("name_zh_cn")
  priceMonthly     Decimal  @map("price_monthly") @db.Decimal(10, 2)
  priceAnnual      Decimal  @map("price_annual") @db.Decimal(10, 2)
  currency         String   @default("USD")
  features         Json // Array of feature strings
  readingsPerMonth Int      @map("readings_per_month") // legacy display label; actual grant comes from monthlyCredits
  monthlyCredits   Int      @default(0) @map("monthly_credits") // Basic:5, Pro:15, Master:50
  isActive         Boolean  @default(true) @map("is_active")
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("plans")
}

// Promo Codes
model PromoCode {
  id            String       @id @default(uuid())
  code          String       @unique
  discountType  DiscountType @map("discount_type")
  discountValue Decimal      @map("discount_value") @db.Decimal(10, 2)
  maxUses       Int          @map("max_uses")
  currentUses   Int          @default(0) @map("current_uses")
  validFrom     DateTime     @map("valid_from")
  validUntil    DateTime     @map("valid_until")
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")

  @@map("promo_codes")
}

// Payment Gateway Config
model PaymentGateway {
  id        String   @id @default(uuid())
  provider  String // e.g., 'stripe', 'line_pay', 'alipay'
  region    String // e.g., 'global', 'taiwan', 'hong_kong', 'malaysia'
  isActive  Boolean  @default(true) @map("is_active")
  config    Json? // Provider-specific config (non-sensitive)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([provider, region])
  @@map("payment_gateways")
}

// AI Prompt Templates (admin-editable per reading type AND per provider)
model PromptTemplate {
  id                       String      @id @default(uuid())
  readingType              ReadingType @map("reading_type")
  aiProvider               AIProvider  @map("ai_provider")
  version                  Int         @default(1)
  systemPrompt             String      @map("system_prompt") @db.Text
  userPromptTemplate       String      @map("user_prompt_template") @db.Text
  outputFormatInstructions String?     @map("output_format_instructions") @db.Text
  isActive                 Boolean     @default(true) @map("is_active")
  createdAt                DateTime    @default(now()) @map("created_at")
  updatedAt                DateTime    @updatedAt @map("updated_at")

  @@unique([readingType, aiProvider, version])
  @@map("prompt_templates")
}

// Admin Audit Log
model AdminAuditLog {
  id          String   @id @default(uuid())
  adminUserId String   @map("admin_user_id")
  action      String // e.g., 'update_plan_price', 'toggle_service'
  entityType  String   @map("entity_type") // e.g., 'plan', 'service', 'promo_code'
  entityId    String?  @map("entity_id")
  oldValue    Json?    @map("old_value")
  newValue    Json?    @map("new_value")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([adminUserId])
  @@map("admin_audit_log")
}

// ============================================================
// Credit Packages (bulk purchase — Stream 5)
// ============================================================

model CreditPackage {
  id           String   @id @default(uuid())
  slug         String   @unique
  nameZhTw     String   @map("name_zh_tw")
  nameZhCn     String   @map("name_zh_cn")
  creditAmount Int      @map("credit_amount")
  priceUsd     Decimal  @map("price_usd") @db.Decimal(10, 2)
  isActive     Boolean  @default(true) @map("is_active")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("credit_packages")
}

// ============================================================
// Ad Reward Logs (rewarded video ads — Stream 4)
// ============================================================

model AdRewardLog {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  rewardType     AdRewardType @map("reward_type")
  adNetworkId    String?      @map("ad_network_id")
  creditsGranted Int          @default(0) @map("credits_granted")
  sectionKey     String?      @map("section_key")
  readingId      String?      @map("reading_id")
  createdAt      DateTime     @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("ad_reward_logs")
}

// ============================================================
// Section Unlocks (per-section unlock — Stream 3)
// ============================================================

model SectionUnlock {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  readingId    String       @map("reading_id") // Generic: BaziReading.id OR ZWDS reading ID
  readingType  String       @default("bazi") @map("reading_type") // "bazi" or "zwds" discriminator
  sectionKey   String       @map("section_key") // e.g., "personality", "career", "love", "finance", "health"
  unlockMethod UnlockMethod @map("unlock_method")
  creditsUsed  Int          @default(0) @map("credits_used")
  isRefunded   Boolean      @default(false) @map("is_refunded")
  createdAt    DateTime     @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  // NOTE: No FK to BaziReading — readingId is generic to support both Bazi and ZWDS readings.
  // Ownership validated in application code (section-unlock.service.ts).

  @@unique([userId, readingId, sectionKey])
  @@index([readingId])
  @@map("section_unlocks")
}

// ============================================================
// Monthly Credits Log (subscription credit grants)
// ============================================================

model MonthlyCreditsLog {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  creditAmount Int      @map("credit_amount")
  periodStart  DateTime @map("period_start")
  periodEnd    DateTime @map("period_end")
  grantedAt    DateTime @default(now()) @map("granted_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodStart])
  @@index([userId])
  @@map("monthly_credits_logs")
}

// ============================================================
// Credit Ledger (per-credit-movement audit trail)
// Added by ai-retry-and-credit-refund plan. Append-only ledger.
// Negative amount = deduction (reading creation, recalc, etc.)
// Positive amount = grant or refund (Stripe purchase, ad reward, AI failure refund).
// ============================================================

model CreditLedger {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  amount       Int // signed: negative = deduction, positive = grant/refund
  reason       String // e.g., "reading-create:CAREER", "refund: ai-failed-..."
  readingId    String?  @map("reading_id")
  comparisonId String?  @map("comparison_id")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  reading    BaziReading?    @relation(fields: [readingId], references: [id], onDelete: SetNull)
  comparison BaziComparison? @relation(fields: [comparisonId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([readingId])
  @@index([comparisonId])
  @@map("credit_ledger")
}

// ============================================================
// AI Chat (per next-the-big-feature-proud-manatee plan)
// Chat lets users ask questions about their Bazi reading.
// Subscribers get free monthly chats (FREE=0, BASIC=15, PRO=30, MASTER=60);
// after exhaustion, 1 credit unlocks 10 messages in current session;
// each additional credit extends current session by 10 more, up to 30-msg hard cap.
// ============================================================

model ChatSession {
  id                  String      @id @default(uuid())
  userId              String      @map("user_id")
  // Phase 3 — was NOT NULL FK to BaziReading. Now nullable to support
  // COMPATIBILITY chat which references BaziComparison instead. Exactly one
  // of (readingId, comparisonId) MUST be set per session (DB CHECK constraint
  // enforced via raw SQL migration since Prisma can't express it).
  readingId           String?     @map("reading_id") // FK -> BaziReading.id (or NULL for COMPAT)
  comparisonId        String?     @map("comparison_id") // Phase 3 — FK -> BaziComparison.id (or NULL for non-COMPAT)
  // Phase 2 — denormalized snapshot of BaziReading.readingType at session
  // create time. Used for hot-path prompt routing (avoids JOIN on every
  // message) AND analytics queries (cost watchdog buckets by this column).
  // Resilient to any future BaziReading.readingType drift.
  // Default LIFETIME is BOTH (a) a safe fallback for existing Phase 1 rows
  // (all of which are LIFETIME) during migration, AND (b) a defensive
  // default if a future code path ever forgets to pass readingType to
  // createSession (the prompt assembled would just be the LIFETIME prompt,
  // which is the most permissive — no broken UX).
  readingType         ReadingType @default(LIFETIME) @map("reading_type")
  // Phase Fortune — FORTUNE chat scope (day/month/year). NULL for non-FORTUNE
  // sessions. Denormalized at session create; used for topic-scope + refuse
  // template + few-shots routing within FORTUNE.
  fortuneScope        FortuneScope? @map("fortune_scope")
  // Phase Fortune — date the fortune session was anchored to (NULL for
  // non-FORTUNE). For DAY scope = the Bazi day; for MONTH = 1st of month;
  // for YEAR = 1st of year. Snapshot at session create — DB row immune to
  // user navigating to another date later.
  fortuneAnchorDate   DateTime?   @map("fortune_anchor_date") @db.Date
  // Phase Fortune chat — denormalized BirthProfile reference for FORTUNE
  // sessions (NULL for non-FORTUNE which reference readingId/comparisonId).
  // Locked per plan NEW-C re-review: storing here avoids the round-trip to
  // derive profileId from snapshot on every sendMessage. FK with SET NULL
  // so deleted-profile sessions preserve history.
  profileId           String?     @map("profile_id")
  startedAt           DateTime    @default(now()) @map("started_at")
  firstMessageAt      DateTime?   @map("first_message_at") // null until user sends 1st message
  endedAt             DateTime?   @map("ended_at") // null until 30-msg cap / 24h inactivity / user-ended
  messageCount        Int         @default(0) @map("message_count") // hard cap at 30
  freeQuotaConsumed   Int         @default(0) @map("free_quota_consumed") // count of msgs paid via subscriber free quota
  creditExtensions    Int         @default(0) @map("credit_extensions") // 1 credit = 10 more paid allowance
  paidMessagesUsed    Int         @default(0) @map("paid_messages_used") // count consumed against creditExtensions × 10
  // Phase 2 — server-side counter for «consecutive AI topic-boundary refuses».
  // Increments via atomic Prisma `{ increment: 1 }` when a stream-complete
  // assistant message matches CHAT_V1_TOPIC_REFUSE_OPENING_REGEX. Resets via
  // atomic `{ set: 0 }` on a non-refuse reply. Used to fire the soft-warning
  // dialog at 5+ consecutive refuses (UX guard rail; user is confused about
  // topic scope and needs to navigate to the correct reading).
  consecutiveRefuses  Int         @default(0) @map("consecutive_refuses")
  refundedAt          DateTime?   @map("refunded_at")
  refundReason        String?     @map("refund_reason")
  contextVersion      String      @map("context_version") // snapshot of CHAT_PROMPT_VERSIONS[readingType] at create
  preAnalysisVersion  String      @map("pre_analysis_version") // snapshot of PRE_ANALYSIS_VERSIONS at create
  hardDeleteAt        DateTime    @map("hard_delete_at") // = startedAt + 12 months (PDPA)
  createdAt           DateTime    @default(now()) @map("created_at")

  // Relations
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  reading    BaziReading?    @relation(fields: [readingId], references: [id], onDelete: Cascade)
  comparison BaziComparison? @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  profile    BirthProfile?   @relation(fields: [profileId], references: [id], onDelete: SetNull)
  messages   ChatMessage[]

  @@index([userId, readingId, startedAt])
  // Phase 2 analytics index — cost watchdog buckets by readingType
  @@index([userId, readingType, startedAt])
  // Phase 3 analytics index — COMPAT sessions queried by comparisonId
  @@index([userId, comparisonId, startedAt])
  @@index([readingId])
  @@index([comparisonId])
  // Phase Fortune chat — analytics + admin queries bucket by profile
  @@index([profileId])
  @@index([hardDeleteAt]) // for cleanup cron
  @@map("chat_sessions")
}

model ChatMessage {
  id                    String    @id @default(uuid())
  sessionId             String    @map("session_id")
  role                  ChatRole
  content               String    @db.Text
  sectionContextHint    String?   @map("section_context_hint") // metadata only
  tokensInput           Int?      @map("tokens_input")
  tokensOutput          Int?      @map("tokens_output")
  cacheReadTokens       Int?      @map("cache_read_tokens") // from Anthropic usage.cache_read_input_tokens
  cacheCreationTokens   Int?      @map("cache_creation_tokens") // from usage.cache_creation_input_tokens
  model                 String? // e.g., "claude-sonnet-4-5-20250929"
  bannedPhraseStripped  Boolean   @default(false) @map("banned_phrase_stripped")
  citationAutoPrepended Boolean   @default(false) @map("citation_auto_prepended")
  llmJudgeVerdict       String?   @map("llm_judge_verdict") // 'pass' | 'fail' | null
  errorCode             String?   @map("error_code") // original error reason (e.g. 'AI_FAILED'), preserved across refund
  isRegrounding         Boolean   @default(false) @map("is_regrounding") // true for synthetic <system-reminder> messages
  // Phase 2 — true when the assistant message is a topic-boundary refusal
  // (matched CHAT_V1_TOPIC_REFUSE_OPENING_REGEX in the post-stream block).
  // Refuse messages are NOT BILLED — refundLastMessage is called immediately
  // after the message is persisted, undoing the upfront deduction. Set in the
  // same Prisma create call as the message itself (no second update).
  isRefuse              Boolean   @default(false) @map("is_refuse")
  paymentMethod         String?   @map("payment_method") // 'FREE_QUOTA' | 'PAID_ALLOWANCE' | null (for refund routing)
  refundedAt            DateTime? @map("refunded_at") // null until refunded; idempotency guard for refundLastMessage
  createdAt             DateTime  @default(now()) @map("created_at")

  // Relations
  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

model ChatMonthlyUsage {
  id               String           @id @default(uuid())
  userId           String           @map("user_id")
  periodStart      DateTime         @map("period_start") // 1st of month UTC
  chatsUsed        Int              @default(0) @map("chats_used") // count of MESSAGES consumed against free quota
  monthlyQuota     Int              @map("monthly_quota") // snapshot at period creation: FREE=0, BASIC=15, PRO=30, MASTER=60
  subscriptionTier SubscriptionTier @map("subscription_tier") // snapshot for audit
  lastTierChangeAt DateTime?        @map("last_tier_change_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodStart])
  @@index([periodStart])
  @@map("chat_monthly_usage")
}

// Phase 2 — per-reading-type sample questions for the chat InlineAskCard
// (per-section) and ChatFloatingButton empty-state (sectionKey=NULL).
// Replaces the hardcoded LIFETIME_SAMPLE_QUESTIONS in
// apps/web/app/components/chat/sample-questions.ts. Admin-editable via
// /admin/chat-questions; cached in memory with batch-aware version-stamp
// invalidation (single increment per write batch, not per-row).
model ChatSampleQuestion {
  id             String      @id @default(uuid())
  readingType    ReadingType @map("reading_type")
  // Section key within the reading. NULL for the «general» empty-state
  // questions used in the ChatFloatingButton drawer (no section context).
  sectionKey     String?     @map("section_key")
  questionText   String      @map("question_text") @db.Text
  // Sort order within a (readingType, sectionKey) group. Lower = first.
  displayOrder   Int         @default(0) @map("display_order")
  isActive       Boolean     @default(true) @map("is_active")
  // Locale code for future i18n. Default zh-TW; queries filter on this.
  locale         String      @default("zh-TW")
  // Phase 2 月運 (2026-05-28): scope discriminator for FORTUNE questions.
  // NULL is treated as DAY for back-compat (all pre-Phase-2 FORTUNE rows
  // are DAY-scope). Per plan v3 M-new-1 — column approach (not sectionKey
  // prefix) because column allows clean WHERE filtering + future YEAR
  // scope extension. Other reading types (LIFETIME/LOVE/CAREER/ANNUAL/
  // COMPATIBILITY) leave this NULL.
  fortuneScope   FortuneScope? @map("fortune_scope")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@index([readingType, sectionKey, isActive, locale])
  @@index([readingType, locale]) // for general (sectionKey=NULL) lookup
  // Phase 2 月運 index for fortuneScope-filtered queries (added when
  // L3.5b sample-questions controller fortuneScope query param ships).
  @@index([readingType, fortuneScope, sectionKey, isActive, locale])
  @@map("chat_sample_questions")
}

// ============================================================
// Daily/Monthly/Yearly Fortune (八字日運/月運/年運)
//
// Per plan `.claude/plans/ok-next-big-feature-merry-cake.md`:
// - Free users see current day/month/year only
// - Subscribers see current + 1 prior period + future window (Day +30 /
//   Month +12 / Year +5)
// - Hybrid cached AI: engine pre-analysis is deterministic; AI narrative
//   cached per (chartHash, date, scope). 1 generation per unique chart
//   per scope per period
// - 7-label is source of truth; 0-100 energy score derived for display
// - 流日 is TRIGGER not verdict — anti-hallucination clauses enforce
//   soft-trigger language in AI prompts
// ============================================================

model DailyFortuneSnapshot {
  id                 String        @id @default(uuid())
  chartHash          String        @map("chart_hash") // hash of birth pillars + gender
  birthProfileId     String?       @map("birth_profile_id") // FK -> BirthProfile (NULL if chart came from ad-hoc input)
  birthProfile       BirthProfile? @relation(fields: [birthProfileId], references: [id], onDelete: SetNull)
  scope              FortuneScope  // DAY | MONTH | YEAR
  anchorDate         DateTime      @map("anchor_date") @db.Date // Bazi-boundary day (or 1st of month/year for MONTH/YEAR)
  yearMonth          String?       @map("year_month") // 'YYYY-MM' for MONTH scope (denormalized for indexing)
  year               Int? // YYYY for YEAR scope (denormalized for indexing)
  engineOutputJson   Json          @map("engine_output_json") // structured pre-analysis from packages/bazi-engine
  aiNarrativeJson    Json?         @map("ai_narrative_json") // AI-generated narrative (cached). NULL = engine-only (preview tabs)
  energyScore        Int?          @map("energy_score") // derived 0-100 advisory (denormalized from engineOutput for filtering)
  auspiciousnessLabel String?      @map("auspiciousness_label") // 7-tier label (denormalized)
  preAnalysisVersion String        @map("pre_analysis_version") // matches FORTUNE_PRE_ANALYSIS_VERSIONS[scope]
  promptVersion      String?       @map("prompt_version") // matches FORTUNE_PROMPT_VERSIONS[scope]; NULL when aiNarrativeJson is NULL
  // AI failure circuit breaker (PR review #4 — 2026-05-17). Prevents
  // unbounded retry-loop Anthropic spend during sustained AI outages:
  // after MAX_AI_FAILURES consecutive failures, serve engine-only output
  // for AI_FAILURE_BACKOFF_HOURS before re-attempting. Counter resets to
  // 0 on a successful AI call (non-null promptVersion).
  aiFailureCount     Int           @default(0) @map("ai_failure_count")
  aiLastFailedAt     DateTime?     @map("ai_last_failed_at")
  generatedAt        DateTime      @default(now()) @map("generated_at")

  @@unique([chartHash, scope, anchorDate])
  @@index([birthProfileId, scope, anchorDate])
  @@index([generatedAt]) // for purge cron
  @@map("daily_fortune_snapshots")
}

// ============================================================
// Dashboard Banner (admin-managed homepage carousel)
//
// Image-only clickable slides shown in apps/web HeroBanner. Admin uploads
// separate desktop + mobile crops to Cloudflare R2 and sets an internal
// link target (e.g. "/reading/annual"). Public read at GET /api/banners
// returns active slides ordered by displayOrder. See plan
// `.claude/plans/1-how-the-image-mutable-anchor.md`.
// ============================================================

model BannerSlide {
  id              String   @id @default(uuid())
  // Admin-only label to identify the slide in the admin list (NOT rendered).
  label           String?
  // R2 public URLs for the two art-directed crops (see plan for recommended
  // sizes: desktop ~1920×384, mobile ~1200×420).
  imageUrlDesktop String   @map("image_url_desktop")
  imageUrlMobile  String   @map("image_url_mobile")
  // Internal absolute path the slide links to, e.g. "/reading/lifetime".
  // Validated server-side to reject external / protocol-relative URLs.
  linkHref        String   @map("link_href")
  // Image alt text for accessibility.
  altText         String?  @map("alt_text")
  // Sort order in the carousel. Lower = first. Tie-break by createdAt.
  displayOrder    Int      @default(0) @map("display_order")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([isActive, displayOrder])
  @@map("banner_slides")
}

